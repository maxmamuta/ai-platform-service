{
  "name": "ai-platform-service",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "compile": "npx tsc",
    "compile:core": "pnpm --dir packages/core run compile",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.+(ts|tsx|js|jsx|json|css|md)\"",
    "typecheck": "tsc --noEmit",
    "typecheck:core": "pnpm --dir packages/core run typecheck",
    "dev:api": "tsx apps/api/index.ts",
    "dev:worker": "tsx apps/worker/index.ts",
    "dev:core": "pnpm --dir packages/core run dev",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "start:core": "node packages/core/dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  }
}
