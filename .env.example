# PostgreSQL Server Connection Details
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional: New Database and User Details (often used with Docker setups)
DB_NAME=
DB_USER=
DB_PASSWORD=

# Optional: Full database connection URL (commonly used in web frameworks like Prisma/Laravel)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${DB_NAME}?sslmode=disable"